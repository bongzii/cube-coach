{
  "name": "cube-coach",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron.cjs",
  "description": "Rubik's Cube OLL/PLL Trainer — Learn and practice algorithms with interactive 3D cube visualizations and a built-in stopwatch.",
  "author": "Cube Coach Team",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js release",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently -k \"vite --port=3000\" \"sleep 3 && electron .\"",
    "electron:build": "vite build && electron-builder --mac",
    "generate-scrambles": "node scripts/generate-scrambles.mjs",
    "cli": "python3 scripts/cli.py"
  },
  "dependencies": {
    "@capacitor/cli": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@capacitor/ios": "^8.4.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.14.0",
    "@types/ramda": "^0.32.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.1.2",
    "cubejs": "^1.3.2",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-window": "^7.4.1"
  }
}
